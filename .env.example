BOT_TOKEN=
CHANNEL_ID=-1004430092555
ADMIN_ID=7866547022
LOG_LEVEL=info
TMP_DIR=/tmp/media-downloader
DATABASE_PATH=./data/media-engine.db
MAX_CONCURRENT_DOWNLOADS=2
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=15
DOWNLOAD_TIMEOUT_MS=900000
UPLOAD_TIMEOUT_MS=900000
PROVIDER_TIMEOUT_MS=120000
DOWNLOAD_RETRY_ATTEMPTS=3
UPLOAD_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
MAX_TELEGRAM_UPLOAD_MB=50
TELEGRAM_API_ROOT=
PROGRESS_EDIT_INTERVAL_MS=2500

# Stage 2.8 — Production readiness & queue reliability.
# All entries below have safe defaults; existing deployments keep working
# without setting them. See docs/PRODUCTION_DEPLOYMENT.md.

# Drive Bridge API (optional — Stage 3 link). When both are set, /health
# probes /api/v1/integration/health on startup.
DRIVE_API_BASE_URL=
DRIVE_API_KEY=
DRIVE_API_TIMEOUT_MS=10000

# Stage 4.0 — Drive sync (post-upload + post-download).
DRIVE_SYNC_MAX_ATTEMPTS=3
DRIVE_SYNC_FAVORITE_BY_DEFAULT=false
DRIVE_SYNC_FOLDER_NAME=Telegram Media Downloader

# Queue recovery & retry
QUEUE_RECOVERY_ENABLED=true
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_BASE_DELAY_MS=2000
QUEUE_DEAD_LETTER_ENABLED=true
QUEUE_PROCESSING_TIMEOUT_MS=1800000

# Background worker
WORKER_ENABLED=true
WORKER_TICK_MS=1000
WORKER_GRACEFUL_SHUTDOWN_MS=15000

# Health & monitoring
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT_MS=8000
HEALTH_CHECK_FAIL_ON_DRIVE_ERROR=false
METRICS_FLUSH_INTERVAL_MS=15000
